# ============================================================
# Dependências
# ============================================================
node_modules/

# ============================================================
# Variáveis de ambiente (nunca subir segredos)
# ============================================================
.env
.env.local
.env.*.local

# ============================================================
# Banco de dados SQLite (gerado pelo Prisma em dev)
# ============================================================
backend/prisma/*.db
backend/prisma/*.db-journal

# ============================================================
# Uploads e arquivos gerados pelos usuários
# ============================================================
backend/uploads/*
!backend/uploads/.gitkeep

# ============================================================
# XMLs e saídas de testes locais (pasta raiz)
# ============================================================
xml_entrada/
xml_saida/
output/
Saidas/
backend/Saidas/

# ============================================================
# Código legado Python (não faz parte do sistema novo)
# ============================================================
python_legacy/

# ============================================================
# Builds de produção
# ============================================================
frontend/dist/
frontend/build/

# ============================================================
# Logs
# ============================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================
# Cache / ferramentas
# ============================================================
.cache/
.vite/
.eslintcache
.parcel-cache/

# ============================================================
# IDEs e ferramentas locais
# ============================================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
.claude/

# package-lock.json orphan na raiz (sem package.json)
/package-lock.json

# ============================================================
# Sistema operacional
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
